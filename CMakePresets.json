        "CMAKE_C_COMPILER_TARGET": "aarch64-linux-gnu",
        "CMAKE_CXX_COMPILER_TARGET": "aarch64-linux-gnu",
        "CMAKE_C_FLAGS_DEBUG": "-O0",
        "CMAKE_CXX_FLAGS_DEBUG": "-O0",
        "CMAKE_C_FLAGS_RELEASE": "-O3",
        "CMAKE_CXX_FLAGS_RELEASE": "-O3"
      }
    },
    {
      "name": "web",
      "generator": "Ninja Multi-Config",
      "toolchainFile": "${sourceDir}/CMake/Toolchains/Web.cmake",
      "binaryDir": "${sourceDir}/CMakeOut/Web",
      "cacheVariables": {
        "MOONCHILD_TARGET_ARCH": "Web",
        "CMAKE_C_FLAGS_DEBUG": "-O0",
        "CMAKE_CXX_FLAGS_DEBUG": "-O0",
        "CMAKE_C_FLAGS_RELEASE": "-O3",
        "CMAKE_CXX_FLAGS_RELEASE": "-O3",
        "CMAKE_EXE_LINKER_FLAGS_DEBUG": "-O0",
        "CMAKE_EXE_LINKER_FLAGS_RELEASE": "-O3"
      }
