{
  "version": 4,
  "configurePresets": [
    {
      "name": "windowsx64",
      "generator": "Ninja Multi-Config",
      "toolchainFile": "${sourceDir}/CMake/Toolchains/Windows.cmake",
      "binaryDir": "${sourceDir}/CMakeOut/WindowsX64",
      "cacheVariables": {
        "MOONCHILD_TARGET_ARCH": "WindowsX64",
        "CMAKE_C_COMPILER": "clang-cl",
        "CMAKE_CXX_COMPILER": "clang-cl",
        "CMAKE_C_FLAGS_DEBUG": "/Od",
        "CMAKE_CXX_FLAGS_DEBUG": "/Od",
        "CMAKE_C_FLAGS_RELEASE": "/O2 /GL /fp:fast",
        "CMAKE_CXX_FLAGS_RELEASE": "/O2 /GL /fp:fast",
        "CMAKE_EXE_LINKER_FLAGS_RELEASE": "/LTCG",
        "CMAKE_SHARED_LINKER_FLAGS_RELEASE": "/LTCG"
      }
    },
    {
      "name": "windowsx86",
      "generator": "Ninja Multi-Config",
      "toolchainFile": "${sourceDir}/CMake/Toolchains/Windows.cmake",
      "binaryDir": "${sourceDir}/CMakeOut/WindowsX86",
      "cacheVariables": {
        "MOONCHILD_TARGET_ARCH": "WindowsX86",
        "CMAKE_C_COMPILER": "clang-cl",
        "CMAKE_CXX_COMPILER": "clang-cl",
        "CMAKE_C_FLAGS_DEBUG": "/Od",
        "CMAKE_CXX_FLAGS_DEBUG": "/Od",
        "CMAKE_C_FLAGS_RELEASE": "/O2 /GL /fp:fast",
        "CMAKE_CXX_FLAGS_RELEASE": "/O2 /GL /fp:fast",
        "CMAKE_EXE_LINKER_FLAGS_RELEASE": "/LTCG",
        "CMAKE_SHARED_LINKER_FLAGS_RELEASE": "/LTCG"
