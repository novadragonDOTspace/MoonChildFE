{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Debug Game (WindowsX64)",
            "type": "lldb",
            "request": "launch",
            "program": "${workspaceFolder}/Bin/WindowsX64/Debug/MoonChildFE.exe",
            "args": [],
            "cwd": "${workspaceFolder}/Bin/WindowsX64/Debug",
            "preLaunchTask": "Build Game (WindowsX64, Debug)",
        },
        {
            "name": "Debug Game (WindowsX86)",
            "type": "node-terminal",
            "request": "launch",
            "preLaunchTask": "Build Game (WindowsX86, Debug)",
            "command": "powershell.exe -NoProfile -Command \"Set-Location -LiteralPath '${workspaceFolder}/Bin/WindowsX86/Debug'; ./MoonChildFE.exe\"",
        },
        {
            "name": "Debug Game (LinuxX64)",
            "type": "node-terminal",
            "request": "launch",
            "preLaunchTask": "Build Game (LinuxX64, Debug)",
            "command": "wsl.exe --cd \"${workspaceFolder}\\Bin\\LinuxX64\\Debug\" ./MoonChildFE",
        },
        {
            "name": "Debug Game (WASM)",
            "type": "node-terminal",
            "request": "launch",
            "preLaunchTask": "Build Game (WASM, Debug)",
            "cwd": "${workspaceFolder}/Bin/Web/Debug",
            "command": "python -m http.server 8008 --bind 127.0.0.1",
        },
        {
            "name": "Debug Game (macOSUniversal)",
            "type": "node-terminal",
            "request": "launch",
            "preLaunchTask": "Build Game (macOSUniversal, Debug)",
            "command": "open \"${workspaceFolder}/Bin/macOSUniversal/Debug/MoonChildFE.app\"",
        },
        {
            "name": "Run Game (WindowsX64)",
            "type": "lldb",
            "request": "launch",
            "program": "${workspaceFolder}/Bin/WindowsX64/Release/MoonChildFE.exe",
            "args": [],
            "cwd": "${workspaceFolder}/Bin/WindowsX64/Release",
            "preLaunchTask": "Build Game (WindowsX64, Release)",
        },
        {
            "name": "Run Game (WindowsX86)",
            "type": "node-terminal",
            "request": "launch",
            "preLaunchTask": "Build Game (WindowsX86, Release)",
            "command": "powershell.exe -NoProfile -Command \"Set-Location -LiteralPath '${workspaceFolder}/Bin/WindowsX86/Release'; ./MoonChildFE.exe\"",
        },
        {
            "name": "Run Game (LinuxX64)",
            "type": "node-terminal",
            "request": "launch",
            "preLaunchTask": "Build Game (LinuxX64, Release)",
            "command": "wsl.exe --cd \"${workspaceFolder}\\Bin\\LinuxX64\\Release\" ./MoonChildFE",
        },
        {
            "name": "Run Game (WASM)",
            "type": "node-terminal",
            "request": "launch",
            "preLaunchTask": "Build Game (WASM, Release)",
            "cwd": "${workspaceFolder}/Bin/Web/Release",
            "command": "python -m http.server 8008 --bind 127.0.0.1",
        },
        {
            "name": "Run Game (macOSUniversal)",
            "type": "node-terminal",
            "request": "launch",
            "preLaunchTask": "Build Game (macOSUniversal, Release)",
            "command": "open \"${workspaceFolder}/Bin/macOSUniversal/Release/MoonChildFE.app\"",
        },
    ]
}
